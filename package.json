{
  "name": "text-polisher",
  "version": "0.1.0",
  "description": "適当な日本語を丁寧な文章に変換するCLIツール",
  "type": "module",
  "bin": {
    "text-polisher": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["japanese", "polite", "text", "cli", "ai"],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
